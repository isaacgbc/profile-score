{
  "name": "profile-score",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "npx dotenv-cli -e .env.local --override -- prisma generate",
    "db:push": "npx dotenv-cli -e .env.local --override -- prisma db push",
    "db:seed": "npx dotenv-cli -e .env.local --override -- prisma db seed",
    "db:studio": "npx dotenv-cli -e .env.local --override -- prisma studio",
    "db:migrate": "npx dotenv-cli -e .env.local --override -- prisma migrate dev",
    "eval": "npx dotenv-cli -e .env.local --override -- npx tsx --tsconfig tsconfig.json src/lib/eval/run-eval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.97.0",
    "next": "^15.1.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
