generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String    @id @default(uuid()) // matches Supabase auth.users.id
  email                 String    @unique
  name                  String?
  avatarUrl             String?   @map("avatar_url")
  activePlanId          String?   @map("active_plan_id")
  subscriptionStatus    String    @default("none") @map("subscription_status") // none|active|cancelled|expired
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Audit {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  results         Json
  planId          String?  @map("plan_id")
  userInput       Json?    @map("user_input")
  modelUsed       String?  @map("model_used")
  promptVersions  Json?    @map("prompt_versions")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("audits")
}

model Export {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  auditId      String   @map("audit_id")
  exportType   String   @map("export_type")
  format       String
  language     String
  status       String   @default("queued")
  fileUrl      String?  @map("file_url")
  errorMessage String?  @map("error_message")
  planId       String?  @map("plan_id")
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([auditId])
  @@map("exports")
}

model PromptRegistry {
  id          String   @id @default(uuid())
  promptKey   String   @map("prompt_key")
  version     Int      @default(1)
  locale      String   @default("en")
  modelTarget String?  @map("model_target")
  content     String
  status      String   @default("draft")
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([promptKey, version, locale])
  @@index([promptKey, locale, status])
  @@map("prompt_registry")
}

model GenerationCache {
  id             String   @id @default(uuid())
  inputHash      String   @unique @map("input_hash")
  results        Json
  modelUsed      String   @map("model_used")
  promptVersions Json?    @map("prompt_versions")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  @@index([inputHash])
  @@index([expiresAt])
  @@map("generation_cache")
}

model Order {
  id                     String    @id @default(uuid())
  saleId                 String    @unique @map("sale_id") // Crea.la saleId (idempotency key)
  event                  String    // new_sale, new_subscription, subscription_renewal, etc.
  userId                 String?   @map("user_id")
  customerId             String?   @map("customer_id")
  customerEmail          String?   @map("customer_email")
  customerName           String?   @map("customer_name")
  customerCountry        String?   @map("customer_country")
  productId              String?   @map("product_id")
  productName            String?   @map("product_name")
  price                  Float?
  currency               String?
  planId                 String?   @map("plan_id")
  subscriptionId         String?   @map("subscription_id")
  subscriptionInterval   String?   @map("subscription_interval")
  nextBillingDate        DateTime? @map("next_billing_date")
  cancellationDate       DateTime? @map("cancellation_date")
  reconciliationStatus   String    @default("none") @map("reconciliation_status") // none|pending|matched
  isTest                 Boolean   @default(false) @map("is_test")
  rawPayload             Json?     @map("raw_payload")
  createdAt              DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([customerId])
  @@index([customerEmail])
  @@index([event])
  @@index([createdAt])
  @@index([reconciliationStatus])
  @@map("orders")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventName  String   @map("event_name")
  sessionId  String?  @map("session_id")
  userId     String?  @map("user_id")
  auditId    String?  @map("audit_id")
  planId     String?  @map("plan_id")
  sourceType String?  @map("source_type")
  locale     String?
  metadata   Json?
  path       String?
  userAgent  String?  @map("user_agent")
  referrer   String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventName])
  @@index([createdAt])
  @@index([sessionId])
  @@map("analytics_events")
}
